<?xml version="1.0"?>
<robot name="fishbot">

  <!-- ================================================= -->
  <!-- Base Link (Main Body) -->
  <!-- ================================================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.1"/>
      </geometry>

      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="4.00"/>

      <inertia
          ixx="0.01208"
          ixy="0"
          ixz="0"
          iyy="0.03333"
          iyz="0"
          izz="0.03750"/>
    </inertial>

  </link>

  <!-- ================================================= -->
  <!-- Tail Fin -->
  <!-- ================================================= -->

  <link name="tail_link">

    <visual>
      <origin xyz="-0.06 0 0"
              rpy="1.5708 1.5708 0"/>

      <geometry>
        <box size="0.10 0.13 0.02"/>
      </geometry>

      <material name="red">
        <color rgba="1 0.3 0.3 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="-0.06 0 0"
              rpy="1.5708 1.5708 0"/>

      <geometry>
        <box size="0.10 0.13 0.02"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.06 0 0"
              rpy="0 0 0"/>

      <mass value="0.15"/>

      <inertia
          ixx="0.000216"
          ixy="0"
          ixz="0"
          iyy="0.000130"
          iyz="0"
          izz="0.000336"/>
    </inertial>
  </link>

  <!-- Tail Joint -->

  <joint name="tail_joint" type="revolute">

    <origin xyz="-0.15 0 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="tail_link"/>

    <!-- Swing left-right -->

    <axis xyz="0 0 1"/>

    <limit
      lower="-0.7"
      upper="0.7"
      effort="10"
      velocity="4"/>

  </joint>

  <!-- ================================================= -->
  <!-- Left Pectoral Fin -->
  <!-- ================================================= -->

  <link name="left_fin_link">

    <visual>
      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

      <material name="light_blue">
        <color rgba="0.4 0.6 1.0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <mass value="0.03"/>

      <inertia
          ixx="0.0000097"
          ixy="0"
          ixz="0"
          iyy="0.0000128"
          iyz="0"
          izz="0.0000213"/>
      </inertial>

  </link>

  <!-- Left Fin Joint -->

  <joint name="left_fin_joint" type="revolute">

    <origin xyz="0.05 0.075 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="left_fin_link"/>

    <!-- Pitch -->

    <axis xyz="0 1 0"/>

    <limit
      lower="-0.3"
      upper="0.3"
      effort="5"
      velocity="2"/>

  </joint>

  <!-- ================================================= -->
  <!-- Right Pectoral Fin -->
  <!-- ================================================= -->

  <link name="right_fin_link">

    <visual>
      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

      <material name="light_blue">
        <color rgba="0.4 0.6 1.0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <mass value="0.03"/>

      <inertia
          ixx="0.0000097"
          ixy="0"
          ixz="0"
          iyy="0.0000128"
          iyz="0"
          izz="0.0000213"/>
      </inertial>

  </link>

  <!-- Right Fin Joint -->

  <joint name="right_fin_joint" type="revolute">

    <origin xyz="0.05 -0.075 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="right_fin_link"/>

    <!-- Pitch -->

    <axis xyz="0 1 0"/>

    <limit
      lower="-0.3"
      upper="0.3"
      effort="5"
      velocity="2"/>

  </joint>

  <!-- ================================================= -->
  <!-- ros2_control -->
  <!-- ================================================= -->

  <ros2_control name="FishbotSystem" type="system">

    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      <param name="robot_param">robot_description</param>
      <param name="robot_param_node">robot_state_publisher</param>
    </hardware>

    <!-- Tail Joint -->

    <joint name="tail_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Left Fin -->

    <joint name="left_fin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Right Fin -->

    <joint name="right_fin_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

<!-- ================================================= -->
<!-- Gazebo Plugin -->
<!-- ================================================= -->



<gazebo>
  <plugin
      name="gazebo_ros2_control"
      filename="libgazebo_ros2_control.so">

    <parameters>
      $(find fishbot_description)/config/fishbot_controllers.yaml
    </parameters>

  </plugin>
</gazebo>

<gazebo>
  <plugin
      name="fishbot_buoyancy"
      filename="libbuoyancy_plugin.so">
  </plugin>
</gazebo>

<gazebo>
  <plugin
      name="fishbot_drag"
      filename="libdrag_plugin.so">
  </plugin>
</gazebo>

<gazebo>
  <plugin
      name="fishbot_thrust"
      filename="libthrust_plugin.so">
  </plugin>
</gazebo>

</robot>