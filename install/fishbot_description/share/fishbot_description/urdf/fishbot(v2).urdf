<!-- This Urdf version consists of the Fishbot documentation accurate structure -->
<?xml version="1.0"?>
<robot name="fishbot">

  <!-- ================================================= -->
  <!-- Base Link (Main Body) -->
  <!-- ================================================= -->

  <link name="base_link">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.1"/>
      </geometry>

      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.01"
        ixy="0"
        ixz="0"
        iyy="0.01"
        iyz="0"
        izz="0.01"/>
    </inertial>

  </link>

  <!-- ================================================= -->
  <!-- Tail Fin -->
  <!-- ================================================= -->

  <link name="tail_link">

    <visual>
      <origin xyz="-0.06 0 0"
              rpy="1.5708 1.5708 0"/>

      <geometry>
        <box size="0.10 0.13 0.02"/>
      </geometry>

      <material name="red">
        <color rgba="1 0.3 0.3 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="-0.06 0 0"
              rpy="1.5708 1.5708 0"/>

      <geometry>
        <box size="0.10 0.13 0.02"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.06 0 0"
              rpy="0 0 0"/>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.001"/>
    </inertial>

  </link>

  <!-- Tail Joint -->

  <joint name="tail_joint" type="revolute">

    <origin xyz="-0.15 0 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="tail_link"/>

    <!-- Swing left-right -->

    <axis xyz="0 0 1"/>

    <limit
      lower="-0.7"
      upper="0.7"
      effort="10"
      velocity="4"/>

  </joint>

  <!-- ================================================= -->
  <!-- Left Pectoral Fin -->
  <!-- ================================================= -->

  <link name="left_fin_link">

    <visual>

      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

      <material name="light_blue">
        <color rgba="0.4 0.6 1.0 1"/>
      </material>

    </visual>

    <collision>

      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 0.03 0"
              rpy="0 0 0"/>

      <mass value="0.05"/>

      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001"/>

    </inertial>

  </link>

  <!-- Left Fin Joint -->

  <joint name="left_fin_joint" type="revolute">

    <origin xyz="0.05 0.075 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="left_fin_link"/>

    <!-- Pitch -->

    <axis xyz="0 1 0"/>

    <limit
      lower="-0.3"
      upper="0.3"
      effort="5"
      velocity="2"/>

  </joint>

  <!-- ================================================= -->
  <!-- Right Pectoral Fin -->
  <!-- ================================================= -->

  <link name="right_fin_link">

    <visual>

      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

      <material name="light_blue">
        <color rgba="0.4 0.6 1.0 1"/>
      </material>

    </visual>

    <collision>

      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <geometry>
        <box size="0.07 0.06 0.015"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 -0.03 0"
              rpy="0 0 0"/>

      <mass value="0.05"/>

      <inertia
        ixx="0.0001"
        ixy="0"
        ixz="0"
        iyy="0.0001"
        iyz="0"
        izz="0.0001"/>

    </inertial>

  </link>

  <!-- Right Fin Joint -->

  <joint name="right_fin_joint" type="revolute">

    <origin xyz="0.05 -0.075 0"
            rpy="0 0 0"/>

    <parent link="base_link"/>
    <child link="right_fin_link"/>

    <!-- Pitch -->

    <axis xyz="0 1 0"/>

    <limit
      lower="-0.3"
      upper="0.3"
      effort="5"
      velocity="2"/>

  </joint>

</robot>